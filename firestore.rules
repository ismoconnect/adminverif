rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== SOUMISSIONS DE COUPONS =====
    // Clients : lecture + création
    // Admins : mise à jour + suppression (contrôlé côté app par rôle)
    match /coupon_submissions/{document} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ===== DEMANDES DE REMBOURSEMENT =====
    match /refund_requests/{document} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ===== MESSAGES DE CONTACT =====
    match /contact_messages/{document} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ===== PARAMÈTRES API (EmailJS, Telegram) =====
    match /settings/{document} {
      allow read: if true;
      allow write: if true;
    }

    // ===== PARAMÈTRES APP (Suspension du site) =====
    match /app_settings/{document} {
      allow read: if true;
      allow write: if true;
    }

    // ===== COLLECTION ADMINS =====
    match /admins/{document} {
      allow read: if true;
      allow write: if true;
    }

    // ===== LIVE VISITORS =====
    match /live_visitors/{document} {
      allow read: if true;
      allow write: if true;
    }

    // ===== STATISTIQUES DES VISITEURS =====
    match /visitor_stats/{document} {
      allow read: if true;
      allow write: if true;
    }

    // ===== RÈGLE PAR DÉFAUT : TOUT BLOQUER =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
